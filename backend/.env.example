# Server Settings
PORT=5000
NODE_ENV=development

# Database Settings
MONGODB_URI=mongodb://127.0.0.1:27017/taskmanager

# Authentication Settings
JWT_SECRET=super_secret_jwt_sign_key_change_me_in_production

# Frontend Client Address
FRONTEND_URL=http://localhost:5173

# Email Service Settings (SMTP)
# If left blank, a dynamic Ethereal Mail testing account will be generated automatically on startup!
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Task Reminders <noreply@taskmanager.local>
